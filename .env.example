# App settings
APP_NAME=CourseForge
APP_ENV=development
DEBUG=true

# API settings
API_HOST=0.0.0.0
API_PORT=8000

# LLM Provider settings
# Options: openai, gemini, stub
LLM_PROVIDER=stub

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_key_here

# Google Gemini (if LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_key_here

# Default model (gpt-4, gpt-4-turbo, gemini-pro, etc.)
DEFAULT_MODEL=gemini-2.5-pro
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2048

# Generation settings
MAX_ITERATIONS=3
TOKEN_BUDGET_INPUT=500000
TOKEN_BUDGET_OUTPUT=200000

# Observability
LOG_LEVEL=INFO