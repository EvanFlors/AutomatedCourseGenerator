# CourseForge Environment Configuration
# Copy this file to .env and fill in your values

# App settings
APP_NAME=CourseForge
APP_ENV=development
DEBUG=true

# API settings
API_HOST=127.0.0.1
API_PORT=8000

# LLM Provider settings
# Options: openai, gemini, stub
LLM_PROVIDER=gemini

# Google Gemini (if LLM_PROVIDER=gemini)
# Option 1: Use API key
GOOGLE_API_KEY=your_google_api_key_here

# Option 2: Use Google Cloud credentials (Vertex AI)
# GEMINI_USE_CREDENTIALS=true
# GEMINI_LOCATION=us-central1
# GEMINI_SCOPE=https://www.googleapis.com/auth/cloud-platform

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here

# Model settings
# For Gemini: gemini-2.5-pro, gemini-1.5-pro, gemini-1.5-flash, etc.
MODEL=gemini-2.5-pro
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=8192

# Generation settings
MAX_ITERATIONS=3
TOKEN_BUDGET_INPUT=500000
TOKEN_BUDGET_OUTPUT=200000

# Observability
LOG_LEVEL=INFO